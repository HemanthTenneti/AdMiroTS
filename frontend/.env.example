NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
# Must match backend GOOGLE_CLIENT_ID for Google token verification.
# In Google Cloud Console, add BOTH origins for local dev if needed:
# - http://localhost:3000
# - http://127.0.0.1:3000
NEXT_PUBLIC_GOOGLE_CLIENT_ID=your-google-oauth-client-id.apps.googleusercontent.com
