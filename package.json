{
  "name": "admirots",
  "private": true,
  "version": "0.1.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev -w @admiro/api\" \"npm run dev -w @admiro/web\"",
    "build": "npm run build -w @admiro/domain && npm run build -w @admiro/shared && npm run build -w @admiro/api && npm run build -w @admiro/web",
    "typecheck": "npm run typecheck --workspaces"
  },
  "devDependencies": {
    "concurrently": "^9.1.2",
    "typescript": "^6.0.3"
  },
  "dependencies": {
    "google-auth-library": "^10.6.2",
    "zod": "^4.3.6"
  }
}
