{
  "name": "@admiro/api",
  "private": true,
  "version": "0.1.0",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "predev": "npm run build -w @admiro/domain && npm run build -w @admiro/shared",
    "dev": "tsx watch src/index.ts",
    "build": "npm run build -w @admiro/domain && npm run build -w @admiro/shared && tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "typecheck": "npm run typecheck -w @admiro/domain && npm run typecheck -w @admiro/shared && tsc --noEmit",
    "test": "npm run test:unit && npm run test:integration",
    "test:unit": "mocha -r ts-node/register --extension ts \"src/**/*.validation.spec.ts\"",
    "test:integration": "npm run build -w @admiro/domain && npm run build -w @admiro/shared && npm run build && mocha \"dist/integration/**/*.integration.spec.js\"",
    "test:watch": "mocha -r ts-node/register --watch --extension ts \"src/**/*.validation.spec.ts\"",
    "test:coverage": "c8 npm run test"
  },
  "dependencies": {
    "@admiro/domain": "0.1.0",
    "@admiro/shared": "0.1.0",
    "@aws-sdk/client-s3": "^3.940.0",
    "@aws-sdk/s3-request-presigner": "^3.940.0",
    "bcrypt": "^6.0.0",
    "cors": "^2.8.5",
    "dotenv": "^17.2.2",
    "express": "^5.1.0",
    "express-rate-limit": "^8.3.2",
    "google-auth-library": "^10.6.2",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.3",
    "mongoose": "^9.4.1",
    "morgan": "^1.10.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/chai": "^5.2.3",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.3",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/mocha": "^10.0.10",
    "@types/morgan": "^1.9.10",
    "@types/node": "^24.5.2",
    "@types/supertest": "^6.0.3",
    "@vercel/node": "^5.3.22",
    "c8": "^10.1.3",
    "chai": "^6.2.0",
    "mocha": "^11.7.4",
    "mongodb-memory-server": "^10.2.3",
    "supertest": "^7.1.4",
    "tsx": "^4.20.5",
    "typescript": "^5.9.2"
  }
}
