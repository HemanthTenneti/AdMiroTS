{
  "info": {
    "_postman_id": "admirots-complete-collection",
    "name": "AdMiroTS - Complete API Collection",
    "description": "Comprehensive API collection for AdMiroTS Digital Signage & Advertisement Management Platform. Includes all implemented endpoints across 7 modules.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "version": "1.0.0"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:5000/api",
      "type": "string"
    },
    {
      "key": "authToken",
      "value": "",
      "type": "string"
    },
    {
      "key": "userId",
      "value": "user_123abc",
      "type": "string"
    },
    {
      "key": "advertisementId",
      "value": "ad_123abc",
      "type": "string"
    },
    {
      "key": "displayId",
      "value": "disp_123abc",
      "type": "string"
    },
    {
      "key": "loopId",
      "value": "loop_123abc",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "🔐 Authentication",
      "item": [
        {
          "name": "Register User",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"user@example.com\",\n  \"password\": \"SecurePassword123!\",\n  \"firstName\": \"John\",\n  \"lastName\": \"Doe\",\n  \"role\": \"ADVERTISER\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth/register",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "register"]
            }
          }
        },
        {
          "name": "Login User",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"user@example.com\",\n  \"password\": \"SecurePassword123!\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth/login",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "login"]
            }
          }
        }
      ]
    },
    {
      "name": "📢 Advertisements",
      "item": [
        {
          "name": "Create Advertisement",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{authToken}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"adName\": \"Summer Sale 2026\",\n  \"mediaUrl\": \"https://example.com/summer-sale.jpg\",\n  \"mediaType\": \"IMAGE\",\n  \"duration\": 30,\n  \"description\": \"Summer collection at 50% off\",\n  \"targetAudience\": \"18-45\",\n  \"fileSize\": 2048000\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/advertisements",
              "host": ["{{baseUrl}}"],
              "path": ["advertisements"]
            }
          }
        },
        {
          "name": "List Advertisements",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/advertisements?page=1&limit=10",
              "host": ["{{baseUrl}}"],
              "path": ["advertisements"],
              "query": [
                { "key": "page", "value": "1" },
                { "key": "limit", "value": "10" }
              ]
            }
          }
        }
      ]
    },
    {
      "name": "📺 Displays",
      "item": [
        {
          "name": "Create Display",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{authToken}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"displayId\": \"DISPLAY_001\",\n  \"location\": \"Main Hall\",\n  \"layout\": \"LANDSCAPE\",\n  \"resolution\": {\n    \"width\": 1920,\n    \"height\": 1080\n  },\n  \"serialNumber\": \"SN123456789\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/displays",
              "host": ["{{baseUrl}}"],
              "path": ["displays"]
            }
          }
        }
      ]
    },
    {
      "name": "⏳ Display Loops",
      "item": [
        {
          "name": "Create Display Loop",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{authToken}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"loopName\": \"Morning Playlist\",\n  \"displayId\": \"{{displayId}}\",\n  \"rotationType\": \"SEQUENTIAL\",\n  \"displayLayout\": \"FULLSCREEN\",\n  \"description\": \"Main morning rotation\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/display-loops",
              "host": ["{{baseUrl}}"],
              "path": ["display-loops"]
            }
          }
        },
        {
          "name": "List Display Loops",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/display-loops?page=1&limit=10",
              "host": ["{{baseUrl}}"],
              "path": ["display-loops"],
              "query": [
                { "key": "page", "value": "1" },
                { "key": "limit", "value": "10" }
              ]
            }
          }
        },
        {
          "name": "Get Display Loop",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/display-loops/{{loopId}}",
              "host": ["{{baseUrl}}"],
              "path": ["display-loops", "{{loopId}}"]
            }
          }
        },
        {
          "name": "Update Display Loop",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{authToken}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"loopName\": \"Updated Morning Playlist\",\n  \"rotationType\": \"RANDOM\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/display-loops/{{loopId}}",
              "host": ["{{baseUrl}}"],
              "path": ["display-loops", "{{loopId}}"]
            }
          }
        },
        {
          "name": "Delete Display Loop",
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{authToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/display-loops/{{loopId}}",
              "host": ["{{baseUrl}}"],
              "path": ["display-loops", "{{loopId}}"]
            }
          }
        },
        {
          "name": "Add Advertisement to Loop",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{authToken}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"advertisementId\": \"{{advertisementId}}\",\n  \"duration\": 30,\n  \"order\": 0,\n  \"weight\": 1\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/display-loops/{{loopId}}/advertisements",
              "host": ["{{baseUrl}}"],
              "path": ["display-loops", "{{loopId}}", "advertisements"]
            }
          }
        },
        {
          "name": "Remove Advertisement from Loop",
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{authToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/display-loops/{{loopId}}/advertisements/{{advertisementId}}",
              "host": ["{{baseUrl}}"],
              "path": ["display-loops", "{{loopId}}", "advertisements", "{{advertisementId}}"]
            }
          }
        },
        {
          "name": "Update Advertisement Order",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{authToken}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"newOrder\": 1\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/display-loops/{{loopId}}/advertisements/{{advertisementId}}/order",
              "host": ["{{baseUrl}}"],
              "path": ["display-loops", "{{loopId}}", "advertisements", "{{advertisementId}}", "order"]
            }
          }
        }
      ]
    },
    {
      "name": "📊 Analytics",
      "item": [
        {
          "name": "Record Analytics Event",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"displayId\": \"{{displayId}}\",\n  \"adId\": \"{{advertisementId}}\",\n  \"loopId\": \"{{loopId}}\",\n  \"impressions\": 1,\n  \"viewDuration\": 30,\n  \"completedViews\": 1,\n  \"metrics\": {\n    \"clicks\": 0,\n    \"interactions\": 1\n  },\n  \"metadata\": {\n    \"deviceType\": \"SMART_TV\",\n    \"location\": \"Main Hall\"\n  }\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/analytics/record",
              "host": ["{{baseUrl}}"],
              "path": ["analytics", "record"]
            }
          }
        },
        {
          "name": "List Analytics",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{authToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/analytics?page=1&limit=10",
              "host": ["{{baseUrl}}"],
              "path": ["analytics"],
              "query": [
                { "key": "page", "value": "1" },
                { "key": "limit", "value": "10" }
              ]
            }
          }
        },
        {
          "name": "Get Aggregated Stats",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{authToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/analytics/stats?adId={{advertisementId}}",
              "host": ["{{baseUrl}}"],
              "path": ["analytics", "stats"],
              "query": [
                { "key": "adId", "value": "{{advertisementId}}" }
              ]
            }
          }
        }
      ]
    },
